{
  "name": "helenvanderwende.github.io",
  "version": "1.0.0",
  "description": "Portfolio website",
  "scripts": {
    "build": "eleventy && tailwindcss -i ./src/css/main.css -o ./dist/public/css/main.css",
    "serve": "eleventy --serve & tailwindcss -i ./src/css/main.css -o ./dist/public/css/main.css --watch"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@tailwindcss/cli": "^4.3.2",
    "eleventy-plugin-metagen": "^1.8.4",
    "fast-glob": "^3.3.3",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2"
  }
}
